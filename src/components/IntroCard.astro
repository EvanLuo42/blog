---
import {
  Card,
  CardHeader,
  CardTitle,
  CardContent,
  CardFooter,
} from "@/components/ui/card"

import {Button} from "@/components/ui/button"

import {BlueSkyIcon} from "./BlueSkyIcon";

import {Github, Mail} from "lucide-react";

interface FrontMatter {
    title: string
}

import * as intro from "@/contents/intro.mdx"
import Prose from "./Prose.astro";
---

<Card>
    <CardHeader>
        <CardTitle>{intro.frontmatter.title}</CardTitle>
    </CardHeader>
    <CardContent>
        <Prose>
            <intro.Content/>
        </Prose>
    </CardContent>
    <CardFooter>
        <div class="flex space-x-3">
            <a href="https://github.com/EvanLuo42">
                <Button size="icon">
                    <Github></Github>
                </Button>
            </a>
            <a href="mailto:ziyun.luo@icloud.com">
                <Button size="icon">
                    <Mail></Mail>
                </Button>
            </a>
            <a href="https://bsky.app/profile/el42.cc">
                <Button size="icon">
                    <BlueSkyIcon/>
                </Button>
            </a>
        </div>
    </CardFooter>
</Card>